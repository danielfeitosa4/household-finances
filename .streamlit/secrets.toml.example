# Copie este arquivo para .streamlit/secrets.toml (local) e cole o mesmo
# conteúdo nas "Secrets" do app no Streamlit Community Cloud.
# NÃO faça commit de .streamlit/secrets.toml (ele já está no .gitignore).

[credentials.usernames.daniel]
email = "seu-email@exemplo.com"
name = "Daniel"
# Gere o hash rodando: python scripts/gerar_senha.py
password = "COLE_AQUI_O_HASH_GERADO"

[cookie]
name = "household_finances_auth"
key = "troque-por-uma-chave-aleatoria-longa"
expiry_days = 30

# Banco de dados permanente (para deploy na nuvem).
# Deixe comentado para usar o SQLite local durante o desenvolvimento.
# Cole a "connection string" do seu Postgres (ex: Neon/Supabase):
# [database]
# url = "postgresql://usuario:senha@host/nome_do_banco?sslmode=require"
